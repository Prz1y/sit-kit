 # 定义一个核心函数：创建独立文件夹、初始化日志并执行多个指令
+run_snippet() {
+    local snippet="$1"
+    local log_file="$2"
+    local tmp_script
+    tmp_script=$(mktemp)
+    printf "#!/bin/bash
+set -o pipefail
+%s
+" "$snippet" > "$tmp_script"
+    chmod +x "$tmp_script"
+    bash "$tmp_script" >> "$log_file" 2>&1
+    local exit_code=$?
+    rm -f "$tmp_script"
+    return "$exit_code"
+}
